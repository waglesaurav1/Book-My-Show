(without K8S Stage)
pipeline {
    agent any
    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {
        stage('Clean Workspace') {
            steps { cleanWs() }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'devops', url: 'https://github.com/waglesaurav1/Book-My-Show.git'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    // Use double quotes to ensure $SCANNER_HOME is recognized
                    sh "${SCANNER_HOME}/bin/sonar-scanner -Dsonar.projectName=myproject -Dsonar.projectKey=myproject"
                }
            }
        }
        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: true // Abort if code fails the test
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                dir('bookmyshow-app') { // Using 'dir' is cleaner than 'cd' in Jenkins
                    sh 'npm install'
                }
            }
        }
        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-credentials', toolName: 'docker') {
                        // Build from the subfolder where the Dockerfile lives
                        sh 'docker build -t saurav2059/book-my-show:v1.0.1 bookmyshow-app/'
                        sh 'docker push saurav2059/book-my-show:v1.0.1'
                    }
                }
            }
        }
        stage('Deploy to Container') {
            steps {
                sh '''
                docker stop bms-app || true
                docker rm bms-app || true
                docker run -d --name bms-app -p 3000:3000 saurav2059/book-my-show:v1.0.1
                '''
            }
        }
    }
    post {
        success {
            emailext (
                subject: "SUCCESS: BMS Deployment v1.0.1",
                body: "The SonarQube quality gate passed and the container is live at http://13.48.196.87:3000",
                to: 'saurav34wagle@gmail.com'
            )
        }
        failure {
            emailext (
                subject: "FAILED: BMS Pipeline",
                body: "Build failed. Check Jenkins logs at ${env.BUILD_URL}",
                to: 'saurav34wagle@gmail.com'
            )
        }
    }
}
